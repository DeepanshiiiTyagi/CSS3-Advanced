*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:Arial,sans-serif;
line-height:1.6;
}

nav{
display:flex;
justify-content:space-between;
align-items:center;
padding:1rem;
background:#222;
color:white;
}

nav ul{
display:flex;
gap:1rem;
list-style:none;
}

nav a{
color:white;
text-decoration:none;
}

.hero{
padding:4rem 1rem;
text-align:center;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:1rem;
padding:2rem;
}

.card{
padding:2rem;
background:#f4f4f4;
border-radius:10px;
transition:0.3s;
}

.card:hover{
transform:translateY(-5px);
}

section{
padding:2rem;
}

footer{
text-align:center;
padding:1rem;
background:#222;
color:white;
}

@media(max-width:768px){
nav{
flex-direction:column;
}

nav ul{
flex-direction:column;
text-align:center;
}
}